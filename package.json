{
    "name": "vcon-viewer",
    "displayName": "vCon Viewer",
    "description": "View and interact with IETF vCon files in VSCode",
    "version": "0.0.1",
    "engines": {
        "vscode": "^1.74.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onLanguage:json",
        "onCommand:vcon-viewer.openViewer"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "vcon-viewer.openViewer",
                "title": "Open vCon Viewer",
                "category": "vCon"
            }
        ],
        "views": {
            "explorer": [
                {
                    "id": "vconViewer.view",
                    "name": "vCon Viewer"
                }
            ]
        },
        "menus": {
            "explorer/context": [
                {
                    "command": "vcon-viewer.openViewer",
                    "group": "navigation",
                    "when": "resourceExtname == .json"
                }
            ]
        },
        "configuration": {
            "title": "vCon Viewer",
            "properties": {
                "vconViewer.autoDetect": {
                    "type": "boolean",
                    "default": true,
                    "description": "Automatically detect vCon files"
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "pretest": "npm run compile && npm run lint",
        "lint": "eslint src --ext ts",
        "test": "node ./out/test/runTest.js"
    },
    "devDependencies": {
        "@types/vscode": "^1.74.0",
        "@types/node": "16.x",
        "@typescript-eslint/eslint-plugin": "^6.0.0",
        "@typescript-eslint/parser": "^6.0.0",
        "eslint": "^8.0.0",
        "typescript": "^5.0.0",
        "@vscode/test-electron": "^2.3.8",
        "mocha": "^10.2.0",
        "glob": "^10.3.10"
    },
    "dependencies": {
        "ajv": "^8.12.0"
    }
}